# Flask application
FLASK_ENV=production
FLASK_APP=run.py
SECRET_KEY=replace-with-a-long-random-secret
PREFERRED_URL_SCHEME=https
AUTO_CREATE_SCHEMA_ON_START=0
TRUST_PROXY_HEADERS=1
TRUSTED_PROXY_HOPS=1
RATE_LIMIT_TRUST_PROXY_HEADERS=1

# Database
POSTGRES_DB=retroquest
POSTGRES_USER=retroquest
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql://retroquest:replace-with-a-strong-db-password@db:5432/retroquest
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300
DB_CONNECT_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000
DB_SSL_MODE=prefer

# Redis / caching / sessions
REDIS_URL=redis://redis:6379/0
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://redis:6379/0
CACHE_TIMEOUT=300
ENABLE_SERVER_SIDE_SESSIONS=1
SESSION_TYPE=redis
SESSION_REDIS_URL=redis://redis:6379/1
GAME_STATE_BACKEND=redis
GAME_STATE_PREFIX=retroquest:game

# Uploads
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=10485760

# Authentication / cookies
LOGIN_SESSION_PROTECTION=strong
BCRYPT_LOG_ROUNDS=13
SESSION_COOKIE_NAME=retroquest_session
REMEMBER_COOKIE_NAME=retroquest_remember
WTF_CSRF_TIME_LIMIT=3600

# Rate limiting / brute force protection
RATE_LIMIT_ENABLED=1
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PER_IP=300
RATE_LIMIT_PER_USER=150
BRUTE_FORCE_WINDOW_SECONDS=900
BRUTE_FORCE_MAX_ATTEMPTS=8
BRUTE_FORCE_LOCKOUT_SECONDS=1800
SUSPICIOUS_REQUEST_WINDOW_SECONDS=600
SUSPICIOUS_REQUEST_LIMIT=6
SUSPICIOUS_REQUEST_LOCKOUT_SECONDS=1800

# Security headers
TALISMAN_FORCE_HTTPS=1
TALISMAN_STRICT_TRANSPORT_SECURITY=1
TALISMAN_STRICT_TRANSPORT_SECURITY_MAX_AGE=31536000
TALISMAN_REFERRER_POLICY=strict-origin-when-cross-origin
TALISMAN_CONTENT_SECURITY_POLICY_REPORT_ONLY=0

# Logging
ENABLE_ACCESS_LOGS=1
LOG_DIR=/var/log/retroquest
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_TO_STDOUT=1

# Gunicorn
WEB_CONCURRENCY=4
GUNICORN_WORKER_CLASS=gevent
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_ACCESS_LOG=/var/log/retroquest/gunicorn-access.log
GUNICORN_ERROR_LOG=/var/log/retroquest/gunicorn-error.log

# Admin bootstrap
ADMIN_USER=admin
ADMIN_PASS=replace-with-a-strong-admin-password

# Optional Cloudinary media storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=retroquest

# NowPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1/invoice
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_CALLBACK_URL=https://example.com/webhook
NOWPAYMENTS_SUCCESS_URL=https://example.com/success
NOWPAYMENTS_CANCEL_URL=https://example.com/deposit
NOWPAYMENTS_ALLOWED_HOSTS=nowpayments.io

# Wallet / blockchain
WALLET_ADDRESS=
BSC_RPC=
BSC_RPC_FALLBACK=https://bsc-dataseed.binance.org/
START_BLOCKCHAIN_CHECKER=0
DEPOSIT_TIMEOUT=1200
DEPOSIT_CONFIRMATIONS=3
USDT_TO_POINTS=4000
MIN_DEPOSIT_USDT=5
MIN_DEPOSIT_USDC=5

# Marketplace / app tuning
WORK_REQUEST_FEE_TNNO=10000
POSTS_PER_PAGE=20
MESSAGES_PER_PAGE=20
SLOW_REQUEST_THRESHOLD_MS=250
